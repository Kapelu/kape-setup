#* Valida si la distro es UBUNTU
VALIDAR_DISTRO(){
  log_print info "Validando distribución..."
  sleep 5

  if [ -f /etc/os-release ]; then
    . /etc/os-release
  else
    clear >&3
    print_banner "⛔ No se pudo detectar la Distro‼️"
    sleep 3
    exit 1
  fi

  case "$ID" in
    ubuntu|debian|linuxmint|pop|zorin|elementary|neon)
      log_print ok "Distro soportada: $ID"
      sleep 2
      log_print info "Iniciando sistema..."
      sleep 3
      ;;
    *)
      clear >&3
      print_banner "⛔ Distro no soportada: $ID"
      sleep 3
      exit 1
      ;;
  esac
}
#* Funcion que actualiza APT
UPDATE(){
	log_print info "Actualizando sistema..."
	if ! $SUDO apt-get update; then
		log_print verifail "Error en $SUDO apt-get update"
    return 1
  fi
  if ! $SUDO apt-get dist-upgrade -y; then
    log_print error "Error en dist-upgrade"
    return 1
  fi
  log_print ok "Sistema actualizado correctamente."
}
#* Funcion de limpieza del sistema
CLEAN_SYSTEM() {
    log_print info "🧹 Iniciando limpieza del sistema..."
    # Limpiar paquetes innecesarios
    log_print ok "➤ Eliminando paquetes huérfanos..."
    $SUDO apt-get autoremove -y
    # Limpiar caché de paquetes descargados
    log_print ok "➤ Limpiando caché de APT..."
    $SUDO apt-get clean
    $SUDO apt-get autoclean
    # Limpiar logs antiguos
    log_print ok "➤ Limpiando logs antiguos..."
    $SUDO journalctl --vacuum-time=7d
    # Limpiar miniaturas (thumbnails)
    log_print ok "➤ Eliminando caché de miniaturas..."
    $SUDO rm -rf "$USER_HOME/.cache/thumbnails/"*
    # Limpiar caché de usuario
    log_print ok "➤ Limpiando caché del usuario..."
    rm -rf "$USER_HOME/.cache/"*
    # Limpiar paquetes snap si existen
    if command -v snap >/dev/null 2>&1; then
        log_print ok "➤ Limpiando versiones antiguas de Snap..."
        snap list --all | awk '/disabled/{print $1, $3}' | while read snapname revision; do
            snap remove "$snapname" --revision="$revision"
        done
    fi
		# Eliminar paquetes en estado "rc" (residuos de configs)
		log_print ok "➤ Eliminando paquetes residuales..."
		dpkg -l | awk '/^rc/ { print $2 }' | xargs -r $SUDO apt-get purge -y
    log_print " Limpieza completada."
		sleep 3
}
#* Función full update que llama a update_system y agrega Snap, Flatpak y firmware
FULL_UPDATE() {
    # Llamada a la función UPDATE
    UPDATE || return 1
    # Snap
    if command -v snap >/dev/null 2>&1; then
        log_print info "➤ Actualizando paquetes Snap..."
        $SUDO snap refresh 2>/dev/null
    fi
    # Flatpak
    if command -v flatpak >/dev/null 2>&1; then
        log_print info "➤ Actualizando paquetes Flatpak..."
        $SUDO flatpak update -y 2>/dev/null
    fi
    # Firmware (solo si es UEFI) / Microcode
    if [ -d /sys/firmware/efi ]; then
        if command -v fwupdmgr >/dev/null 2>&1; then
            log_print info "➤ Actualizando firmware (UEFI)..."
            $SUDO fwupdmgr refresh >/dev/null 2>&1
            $SUDO fwupdmgr update >/dev/null 2>&1
        fi
    else
        log_print warn "➤ Sistema en modo Legacy BIOS, se omite firmware."
    fi
    log_print ok "Actualización completa finalizada."
}
#* INSTALL_SNAP: Instala paquetes snap declarados en SNAP_TOOLS
INSTALL_SNAP(){
  log_print info "Instalando paquetes snap desde SNAP_TOOLS..."

  if ! command -v snap >/dev/null 2>&1; then
    log_print warn "snap no está instalado. Instalando snapd..."
    $SUDO apt-get update -y
    $SUDO apt-get install -y snapd
    systemctl enable --now snapd.socket
    ln -sf /var/lib/snapd/snap /snap
  else
    log_print ok "snap disponible"
  fi

  log_print info "Obteniendo lista de snaps instalados..."
  local installed
  installed="$(snap list | awk 'NR>1{print $1}')"

  local pkg
  for pkg in "${SNAP_TOOLS[@]}"; do
    if echo "$installed" | grep -qx "$pkg"; then
      log_print ok "$pkg ya está instalado"
    else
      log_print info "Instalando $pkg..."
      if snap install "$pkg"; then
        log_print ok "$pkg instalado ✔"
      else
        log_print error "Error instalando $pkg"
      fi
    fi
  done

  log_print ok "Instalación de paquetes SNAP finalizado"
}
#* INSTALL_APT: Instala paquetes usando APT_TOOLS
INSTALL_APT() {
  local pkg
  log_print info "Instalando paquetes desde APT_TOOLS..."

  for pkg in "${APT_TOOLS[@]}"; do
    if ! dpkg -s "$pkg" &>/dev/null; then
      log_print run "Instalando paquete: $pkg..."
      
      if ! $SUDO apt-get install -y "$pkg"; then
        log_print warn "Paquete defectuoso: $pkg. Intentando desinstalar..."
        $SUDO apt-get remove -y "$pkg" 2>/dev/null
      else
        log_print ok "Instalado correctamente: $pkg"
      fi
    else
      log_print info "Ya está instalado: $pkg"
    fi
  done
  log_print ok "Instalación de pauqetes APT finalizado"
}
#* INSTALL_BRAVE: Instala Brave
INSTALL_BRAVE() {
  log_print run "Instalando Brave Browser..."

  # Asegurar curl
  if ! dpkg -s curl &>/dev/null; then
    log_print run "Instalando dependencia: curl..."
    if ! $SUDO apt-get update -y; then
      log_print warn "Fallo en apt-get update"
      return 1
    fi
    if ! $SUDO apt-get install -y curl; then
      log_print warn "No se pudo instalar curl"
      return 1
    fi
  fi

  # Limpieza previa (clave para evitar conflicto Signed-By)
  log_print run "Limpiando configuraciones previas de Brave..."
  $SUDO rm -f /etc/apt/sources.list.d/brave-browser*
  $SUDO rm -f /usr/share/keyrings/brave-browser-archive-keyring.gpg
  $SUDO rm -f /etc/apt/keyrings/brave-browser-archive-keyring.gpg

  # Keyrings
  if ! $SUDO mkdir -p /usr/share/keyrings; then
    log_print warn "Error creando directorio keyrings"
    return 1
  fi

  log_print run "Descargando keyring de Brave..."
  if ! curl -fsSL https://brave-browser-apt-release.s3.brave.com/brave-browser-archive-keyring.gpg \
    | $SUDO tee /usr/share/keyrings/brave-browser-archive-keyring.gpg > /dev/null; then
    log_print warn "Error descargando keyring"
    return 1
  fi

	# Repo
  log_print run "Agregando repositorio Brave..."
  if ! curl -fsSL https://brave-browser-apt-release.s3.brave.com/brave-browser.sources \
    | $SUDO tee /etc/apt/sources.list.d/brave-browser-release.sources > /dev/null; then
    log_print warn "Error agregando repositorio"
    return 1
  fi

  log_print run "Actualizando repositorios..."
  if ! $SUDO apt-get update -y; then
    log_print warn "Fallo en apt-get update"
    return 1
  fi

  # Update + install
  log_print run "Instalando brave-browser..."
  if ! $SUDO apt-get install -y brave-browser; then
    log_print warn "No se pudo instalar Brave"
    return 1
  fi

  log_print ok "Brave instalado correctamente"
	log_print ok "Versión" brave-browser --version
}
#* INSTALL_GOOGLE: Instala Google Chrome
INSTALL_GOOGLE() {
  log_print run "Instalación de Google Chrome..."

  $SUDO rm -f /etc/apt/sources.list.d/google-chrome.list
  $SUDO rm -f /etc/apt/keyrings/google-chrome.gpg

  log_print run "Agregando clave oficial (keyring)..."

  if ! $SUDO mkdir -p /etc/apt/keyrings; then
    log_print warn "Error creando keyrings"
    return 1
  fi

  if ! curl -fsSL https://dl.google.com/linux/linux_signing_key.pub \
    | gpg --dearmor | $SUDO tee /etc/apt/keyrings/google-chrome.gpg > /dev/null; then
    log_print warn "Error importando clave"
    return 1
  fi

  if ! $SUDO chmod 644 /etc/apt/keyrings/google-chrome.gpg; then
    log_print warn "Error en permisos del keyring"
    return 1
  fi

  log_print run "Agregando repositorio..."
  if ! echo "deb [arch=amd64 signed-by=/etc/apt/keyrings/google-chrome.gpg] http://dl.google.com/linux/chrome/deb/ stable main" \
    | $SUDO tee /etc/apt/sources.list.d/google-chrome.list > /dev/null; then
    log_print warn "Error agregando repo"
    return 1
  fi

  log_print run "Actualizando repositorios..."
  if ! $SUDO apt-get update; then
    log_print warn "Fallo en apt-get update"
    return 1
  fi

  log_print run "Instalando Google Chrome..."
  if ! $SUDO apt-get install -y google-chrome-stable; then
    log_print warn "No se pudo instalar Chrome"
    return 1
  fi

  log_print ok "Google Chrome instalado correctamente"
	log_print ok "Versión" google-chrome --version
}
#* REMOVE_FIREFOX: Desintala completamente Firefox del sistema, sin dejar residuos.
REMOVE_FIREFOX(){
  log_print info "Detectando instalación de Firefox..."

  local found=false

  # --- SNAP ---
  if command -v snap >/dev/null 2>&1 && snap list 2>/dev/null | grep -q "^firefox"; then
    log_print info "Firefox detectado como SNAP"
    snap remove --purge firefox
    $SUDO rm -rf /var/snap/firefox /var/lib/snapd/snaps/firefox*
    found=true
  fi

  # --- APT ---
  if dpkg -s firefox >/dev/null 2>&1; then
    log_print info "Firefox detectado como paquete APT"
    $SUDO apt-get purge -y firefox
    $SUDO apt-get autoremove -y --purge
    $SUDO rm -f /etc/apt/sources.list.d/*firefox*
    found=true
  fi

  # --- FLATPAK ---
  if command -v flatpak >/dev/null 2>&1 && flatpak list 2>/dev/null | grep -q "org.mozilla.firefox"; then
    log_print info "Firefox detectado como FLATPAK"
    flatpak uninstall -y org.mozilla.firefox --delete-data
    $SUDO rm -rf /var/lib/flatpak/app/org.mozilla.firefox
    found=true
  fi

  if [ "$found" = false ]; then
    log_print warn "Firefox no está instalado por apt, snap ni flatpak"
  fi

  log_print info "Eliminando residuos..."

  # --- USERS ---
  local dir
  for dir in /home/* /root; do
    $SUDO rm -rf "$dir/.mozilla" \
                  "$dir/.cache/mozilla" \
                  "$dir/.config/firefox"
  done

  # --- BINARIOS ---
  $SUDO rm -f /usr/bin/firefox /usr/local/bin/firefox

  # --- SYSTEM ---
  $SUDO rm -rf /usr/lib/firefox \
          /usr/lib/firefox-esr \
          /usr/share/firefox \
          /etc/firefox

  log_print ok "Firefox eliminado completamente"
}
#* INSTALL_NODE: NVM + Node LTS + npm + pnpm
INSTALL_NODE() {
	log_print run "Instalando Node.js (NVM)..."
	local NVM_DIR="$USER_HOME/.nvm"
	local NVM_SCRIPT="$NVM_DIR/nvm.sh"
	# Limpieza previa (opcional, podés comentar si no querés reinstalar)
	if [ -d "$NVM_DIR" ]; then
		log_print warn "NVM ya existe, se reutilizará instalación"
	fi
	# Descargar e instalar NVM
	log_print run "Descargando e instalando NVM..."
	if ! curl -fsSL https://raw.githubusercontent.com/nvm-sh/nvm/v0.40.3/install.sh | bash; then
		log_print error "Error instalando NVM"
		return 1
	fi
	# Cargar NVM en la sesión actual
	log_print run "Cargando entorno NVM..."
	if [ -s "$NVM_SCRIPT" ]; then
		# shellcheck disable=SC1090
		\. "$NVM_SCRIPT"
	else
		log_print error "No se encontró nvm.sh"
		return 1
	fi
	# Instalar Node LTS (v24)
	log_print run "Instalando Node.js v24..."
	if ! nvm install 24; then
		log_print error "Error instalando Node.js"
		return 1
	fi
	if ! nvm use 24; then
		log_print error "Error activando Node.js"
		return 1
	fi
	# Verificar Node
	if ! command -v node >/dev/null 2>&1; then
		log_print error "Node no disponible"
		return 1
	fi
	log_print run "Configurando entorno Node en .bashrc..."
	local BASHRC="$USER_HOME/.bashrc"
	if ! grep -q "NVM_DIR" "$BASHRC"; then
		cat <<EOF >> "$BASHRC"
		# NVM
		export NVM_DIR="\$HOME/.nvm"
		[ -s "\$NVM_DIR/nvm.sh" ] && \. "\$NVM_DIR/nvm.sh"
		# PNPM
		export PNPM_HOME="\$HOME/.local/share/pnpm"
		export PATH="\$PNPM_HOME:\$PATH"
EOF
  fi

  log_print ok "Entorno Node agregado a .bashrc"

  # Activar corepack (incluye pnpm y yarn)
  log_print run "Activando corepack..."
  if ! corepack enable; then
    log_print error "Error activando corepack"
    return 1
  fi

  # Instalar última versión de pnpm
  log_print run "Instalando pnpm..."
  if ! corepack prepare pnpm@latest --activate; then
    log_print error "Error instalando pnpm"
    return 1
  fi

  # Verificar pnpm
  if ! command -v pnpm >/dev/null 2>&1; then
    log_print error "pnpm no disponible"
    return 1
  fi

  # Actualizar npm a latest
  log_print run "Actualizando npm..."
  if ! npm install -g npm@latest; then
    log_print error "Error actualizando npm"
    return 1
  fi

  log_print ok "Node.js + pnpm + npm listos"
	log_print ok "Node instalado: $(node -v)"
