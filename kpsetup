#* INSTALL_CODE: Instala vscode desde el repositorio de APT
INSTALL_CODE() {
  log_print run "Instalando Visual Studio Code..."

  local KEYRING="/etc/apt/keyrings/microsoft.gpg"
  local SOURCE_LIST="/etc/apt/sources.list.d/vscode.list"

  log_print run "Limpiando instalaciones previas..."
  $SUDO rm -f "$SOURCE_LIST"
  $SUDO rm -f "$KEYRING"

  # --- Limpieza previa ---
  log_print INFO "Limpiando instalaciones previas de VS Code..."
  if ! $SUDO apt-get update -y; then
    log_print error "apt update falló"
    return 1
  fi

	# --- Keyring ---
  log_print RUN "Importando clave GPG (keyring)"
  if ! $SUDO mkdir -p /etc/apt/keyrings; then
    log_print error "Error creando keyrings"
    return 1
  fi

  log_print run "Importando clave GPG"
  if ! wget -qO- https://packages.microsoft.com/keys/microsoft.asc \
    | gpg --dearmor | $SUDO tee "$KEYRING" > /dev/null; then
    log_print error "No se pudo importar clave"
    return 1
  fi

  if ! $SUDO chmod 644 "$KEYRING"; then
    log_print error "Error permisos keyring"
    return 1
  fi

  # --- Repo ---
  log_print RUN "Agregando repositorio VS Code"
  if ! echo "deb [arch=amd64 signed-by=$KEYRING] https://packages.microsoft.com/repos/vscode stable main" \
    | $SUDO tee "$SOURCE_LIST" > /dev/null; then
    log_print error "Error agregando repo"
    return 1
  fi

  # --- Instalación ---
  log_print RUN "Actualizando e instalando VSCode"
  if ! $SUDO apt-get update -y; then
    log_print error "apt update falló"
    return 1
  fi

  log_print run "Instalando VSCode..."
  if ! $SUDO apt-get install -y code; then
    log_print error "Error instalando VS Code"
    return 1
  fi

  log_print ok "VS Code instalado correctamente"
	log_print ok "Versión" code --version

}
